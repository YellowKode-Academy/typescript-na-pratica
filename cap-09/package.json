{
  "name": "task-api-cap-09",
  "version": "1.0.0",
  "description": "task-api — cap-09: Prisma + TypeScript",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
